# ============================================================
# Variables d'environnement — Palmarès Scolaires
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env !
# ============================================================

# Django
# Générer avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Django settings module (config.settings.dev ou config.settings.prod)
DJANGO_SETTINGS_MODULE=config.settings.prod

# PostgreSQL
DATABASE_URL=postgres://palmares_user:CHANGE_ME_DB_PASSWORD@db:5432/palmares_db
POSTGRES_DB=palmares_db
POSTGRES_USER=palmares_user
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Production uniquement
# CSRF_TRUSTED_ORIGINS=https://votre-domaine.com
# ALLOWED_HOSTS=votre-domaine.com,www.votre-domaine.com
